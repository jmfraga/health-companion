# Copy this file to .env and fill in real values.
# .env is gitignored — never commit real secrets.

# -----------------------------------------------------------------------------
# Anthropic (Claude Opus 4.7 + Managed Agents)
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...
# The Managed Agents beta header — bump date when Anthropic releases a new version.
ANTHROPIC_BETA_HEADER=managed-agents-2026-04-01

# -----------------------------------------------------------------------------
# Supabase
# -----------------------------------------------------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# -----------------------------------------------------------------------------
# Database (used by SQLAlchemy / Alembic directly)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql+psycopg://postgres:password@localhost:5432/health_companion

# -----------------------------------------------------------------------------
# API runtime
# -----------------------------------------------------------------------------
ENVIRONMENT=development
DEBUG=true
CORS_ORIGINS=["http://localhost:3000"]

# -----------------------------------------------------------------------------
# Optional: Whisper (for PostConsultationAgent audio)
# -----------------------------------------------------------------------------
# OPENAI_API_KEY=sk-...   # only if we use OpenAI Whisper; alternative is self-hosted mlx-audio.

# -----------------------------------------------------------------------------
# Frontend (apps/web) — Next.js uses NEXT_PUBLIC_ prefix for client-exposed vars
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_API_URL=http://localhost:8000
