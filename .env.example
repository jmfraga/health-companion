# Copy this file to .env and fill in real values.
# .env is gitignored — never commit real secrets.

# -----------------------------------------------------------------------------
# Anthropic (Claude Opus 4.7 + Managed Agents)
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...
# Bump the date when Anthropic releases a new Managed Agents beta.
ANTHROPIC_BETA_HEADER=managed-agents-2026-04-01

# -----------------------------------------------------------------------------
# Supabase — new key system (publishable + secret, asymmetric JWT via JWKS).
# -----------------------------------------------------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_SECRET_KEY=sb_secret_...
SUPABASE_JWKS_URL=https://your-project.supabase.co/auth/v1/.well-known/jwks.json
SUPABASE_JWT_KID=                    # Signing key ID (kid), optional — FastAPI matches via JWT header.

# -----------------------------------------------------------------------------
# Database (direct connection for SQLAlchemy / Alembic)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql+psycopg://postgres:YOUR-PASSWORD@db.your-project.supabase.co:5432/postgres

# -----------------------------------------------------------------------------
# API runtime
# -----------------------------------------------------------------------------
ENVIRONMENT=development
DEBUG=true
CORS_ORIGINS=["http://localhost:3000"]

# -----------------------------------------------------------------------------
# Optional: Whisper (for PostConsultationAgent audio)
# -----------------------------------------------------------------------------
# OPENAI_API_KEY=sk-...   # only if we use OpenAI Whisper; alternative is self-hosted mlx-audio.

# -----------------------------------------------------------------------------
# Frontend (apps/web) — Next.js exposes NEXT_PUBLIC_* to the browser.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
NEXT_PUBLIC_API_URL=http://localhost:8000
